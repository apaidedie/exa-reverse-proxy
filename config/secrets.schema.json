{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exa Proxy Secrets Configuration",
  "type": "object",
  "required": ["exaKeys", "proxyTokens", "adminTokens"],
  "properties": {
    "exaKeys": {
      "type": "array",
      "description": "Exa API keys configuration",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "key", "weight"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this key",
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "key": {
            "type": "string",
            "description": "Actual Exa API key",
            "minLength": 10
          },
          "weight": {
            "type": "integer",
            "description": "Weight for load balancing (higher = more traffic)",
            "minimum": 1,
            "default": 1
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this key is enabled",
            "default": true
          },
          "note": {
            "type": "string",
            "description": "Optional note about this key"
          }
        }
      }
    },
    "proxyTokens": {
      "type": "array",
      "description": "Client access tokens (minimum 16 characters)",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 16
      }
    },
    "adminTokens": {
      "type": "array",
      "description": "Admin access tokens (minimum 16 characters)",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 16
      }
    }
  }
}
