{
  "uid": "exa-reverse-proxy",
  "title": "Exa Reverse Proxy",
  "description": "Operational dashboard for the Exa Reverse Proxy — key health, request throughput, rate limits, upstream errors, and connection pool status.",
  "schemaVersion": 39,
  "version": 1,
  "grafanaVersion": "10.0.0",
  "tags": ["exa", "reverse-proxy", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "key",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "definition": "label_values(exa_proxy_requests_total, key_id)",
        "label": "Key",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(exa_proxy_requests_total, key_id)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Keys",
      "description": "Total configured upstream API keys",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_keys_total",
          "instant": true,
          "range": false,
          "legendFormat": "Total keys"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Healthy Keys",
      "description": "Keys currently enabled and outside cooldown",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_keys_healthy",
          "instant": true,
          "range": false,
          "legendFormat": "Healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Cooldown Keys",
      "description": "Keys currently in cooldown",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_keys_cooldown",
          "instant": true,
          "range": false,
          "legendFormat": "Cooldown"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Active Alerts",
      "description": "Active admin-console alerts",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 4, "x": 15, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_alerts_active",
          "instant": true,
          "range": false,
          "legendFormat": "Alerts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "None", "color": "green" } } }
          ],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "P95 Latency",
      "description": "P95 request latency from stored request logs",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_request_latency_p95_ms",
          "instant": true,
          "range": false,
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "ms",
          "mappings": [],
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "title": "Request Rate",
      "description": "Per-second rate of total upstream attempts",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum(rate(exa_proxy_requests_total{key_id=~\"$key\"}[$__rate_interval]))",
          "range": true,
          "instant": false,
          "legendFormat": "Requests/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 11,
      "title": "Success Rate %",
      "description": "Percentage of requests that succeeded (2xx/3xx) out of total attempts",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum(rate(exa_proxy_key_success_total{key_id=~\"$key\"}[$__rate_interval])) / sum(rate(exa_proxy_requests_total{key_id=~\"$key\"}[$__rate_interval])) * 100",
          "range": true,
          "instant": false,
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min"] }
      }
    },
    {
      "id": 12,
      "title": "Failure Rate by Key",
      "description": "Per-second rate of failed upstream attempts, broken down by key",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum by (key_id) (rate(exa_proxy_key_failures_total{key_id=~\"$key\"}[$__rate_interval]))",
          "range": true,
          "instant": false,
          "legendFormat": "{{key_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "failures/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 20,
      "title": "429 Rate Limits by Key",
      "description": "Per-second rate of 429 rate-limit responses, broken down by key",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum by (key_id) (rate(exa_proxy_key_rate_limits_total{key_id=~\"$key\"}[$__rate_interval]))",
          "range": true,
          "instant": false,
          "legendFormat": "{{key_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "rate-limits/s",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      }
    },
    {
      "id": 21,
      "title": "Upstream Errors by Reason",
      "description": "Per-second rate of upstream errors grouped by low-cardinality reason",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum by (reason) (rate(exa_proxy_upstream_error_total[$__rate_interval]))",
          "range": true,
          "instant": false,
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "errors/s",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      }
    },
    {
      "id": 30,
      "title": "Pool Utilization",
      "description": "Percentage of connected pool sockets actively running requests",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_pool_running / (exa_proxy_pool_running + exa_proxy_pool_free) * 100",
          "instant": true,
          "range": false,
          "legendFormat": "Utilization"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 31,
      "title": "Queue Depth",
      "description": "Number of requests currently queued in the upstream connection pool",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_pool_queued",
          "instant": true,
          "range": false,
          "legendFormat": "Queued"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_pool_pending",
          "instant": true,
          "range": false,
          "legendFormat": "Pending"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_pool_running",
          "instant": true,
          "range": false,
          "legendFormat": "Running"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_pool_free",
          "instant": true,
          "range": false,
          "legendFormat": "Free"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_pool_connected",
          "instant": true,
          "range": false,
          "legendFormat": "Connected"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short",
          "min": 0,
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Queued" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Connected" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 40,
      "title": "Per-Key Status Overview",
      "description": "Current snapshot of every key: total requests, successes, failures, rate limits, credits exhausted, and cooldown status",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_requests_total{key_id=~\"$key\"}",
          "instant": true,
          "range": false,
          "legendFormat": "{{key_id}}",
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_key_success_total{key_id=~\"$key\"}",
          "instant": true,
          "range": false,
          "legendFormat": "{{key_id}}",
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_key_failures_total{key_id=~\"$key\"}",
          "instant": true,
          "range": false,
          "legendFormat": "{{key_id}}",
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_key_rate_limits_total{key_id=~\"$key\"}",
          "instant": true,
          "range": false,
          "legendFormat": "{{key_id}}",
          "format": "table"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "exa_proxy_key_credits_exhausted_total{key_id=~\"$key\"}",
          "instant": true,
          "range": false,
